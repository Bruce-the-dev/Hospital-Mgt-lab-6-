type InventoryViewDTO {
    medicationId: ID!
    medicationName: String!
    quantity: Int!
    lastUpdated: String!
}

extend type Query {
    inventoryView(page: Int! ,size:Int!): [InventoryViewDTO!]!
    lowStockItems: [InventoryViewDTO!]!
    inventoryViewPage(page: Int!, size: Int!): InventoryViewDTO!
}


